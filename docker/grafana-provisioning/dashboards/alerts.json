          "rawSql": "SELECT\n    alert_hour AS time,\n    sumIf(alert_count, quarter = 0) AS `0`,\n    sumIf(alert_count, quarter = 1) AS `15`,\n    sumIf(alert_count, quarter = 2) AS `30`,\n    sumIf(alert_count, quarter = 3) AS `45`\nFROM (\n    SELECT\n        toStartOfHour(time_bucket) AS alert_hour,\n        intDiv(toMinute(time_bucket), 15) AS quarter,\n        sum(alert_count) AS alert_count\n    FROM alerts_history\n    WHERE time_bucket >= toStartOfHour(now() - INTERVAL 1 DAY)\n      AND time_bucket <= now()\n    GROUP BY alert_hour, quarter\n) AS subquery\nGROUP BY alert_hour\nORDER BY alert_hour\nWITH FILL\nFROM toStartOfHour(now() - INTERVAL 1 DAY)\nTO toStartOfHour(now())\nSTEP toIntervalHour(1);",
          "refId": "A"
        }
