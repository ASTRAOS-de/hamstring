          "pluginVersion": "4.6.0",
          "queryType": "table",
          "rawSql": "SELECT\n    concat(toString(row_number() OVER (ORDER BY alert_count DESC, src_ip ASC)), '.') AS \"Rank\",\n    src_ip AS \"Client IP address\",\n    alert_count AS \"# Alerts\",\n    ifNull(total_requests, 0) AS \"# Total Requests\"\nFROM (\n    SELECT src_ip, count() AS alert_count\n    FROM alerts\n    WHERE alert_timestamp >= $__fromTime AND alert_timestamp <= $__toTime\n    GROUP BY src_ip\n) AS alert_counts\nLEFT JOIN (\n    SELECT src_ip, count() AS total_requests\n    FROM loglines\n    GROUP BY src_ip\n) AS request_counts USING src_ip\nORDER BY alert_count DESC, src_ip ASC\nLIMIT 5;",
          "refId": "A"
        }
      ],
      "title": "Top 5 most active malicious addresses",
      "transparent": true,
      "type": "table"
