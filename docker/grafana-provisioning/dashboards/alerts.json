          "rawSql": "SELECT\n    toStartOf${Granularity}(time_bucket) AS time_bucket,\n    sum(alert_count) AS \"count\"\nFROM alerts_history\nWHERE time_bucket >= toStartOf${Granularity}(toDateTime($__fromTime))\n  AND time_bucket <= toStartOf${Granularity}(toDateTime($__toTime))\nGROUP BY time_bucket\nORDER BY time_bucket\nWITH FILL\nFROM toStartOf${Granularity}(toDateTime($__fromTime))\nTO toStartOf${Granularity}(toDateTime($__toTime))\nSTEP toInterval${Granularity}(1);",
